<article class="gh-card-more {{post_class}}">
    <a class="gh-card-more-link" href="{{url}}">
        {{#if feature_image}}
        <figure class="gh-card-more-image">
            <img
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 720w,
                        {{img_url feature_image size="l"}} 960w"
                sizes="(max-width: 768px) 100vw, 400px"
                src="{{img_url feature_image size="m"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                loading="lazy"
            >
            {{#match visibility "paid"}}
            <span class="gh-card-premium-badge" title="付费文章">🌟</span>
            {{/match}}
        </figure>
        {{/if}}

        <div class="gh-card-more-content">
            {{#primary_tag}}
            <span class="gh-card-tag">{{name}}</span>
            {{/primary_tag}}
            <h3 class="gh-card-more-title">{{title}}</h3>
            
            {{#if excerpt}}
            <p class="gh-card-more-excerpt">{{excerpt words="20"}}</p>
            {{/if}}
            
            <div class="gh-card-more-meta">
                {{#foreach authors}}{{#if @first}}{{name}}{{/if}}{{/foreach}}
                <span class="gh-meta-sep">&middot;</span>
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="YYYY年M月D日"}}</time>
            </div>
        </div>
    </a>
</article>
