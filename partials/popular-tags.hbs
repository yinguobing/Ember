{{!-- Popular Tags Section - 使用 tag feature_image 作为背景 --}}
{{#if @custom.tag_slugs_for_popular_tags}}
    {{!-- 使用配置的 tag slugs --}}
    {{#get "tags" filter="slug:[{{@custom.tag_slugs_for_popular_tags}}]" include="count.posts"}}
        {{#if tags}}
        <section class="gh-popular-tags">
            <h2 class="gh-section-title">{{t "热门主题"}}</h2>
            <div class="gh-tags-cloud">
                {{#foreach tags}}
                <a href="{{url}}" class="gh-tag-item"
                    style="{{#if feature_image}}background-image: url('{{img_url feature_image size="m"}}');{{/if}}{{#if accent_color}} --tag-accent-color: {{accent_color}};{{/if}}">
                    <span class="gh-tag-overlay"></span>
                    <span class="gh-tag-name">{{name}}</span>
                </a>
                {{/foreach}}
            </div>
            <footer class="gh-popular-tags-footer">
                <a class="gh-more-link" href="{{@site.url}}/tags">
                    {{t "全部主题"}}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </a>
            </footer>
        </section>
        {{/if}}
    {{/get}}
{{else}}
    {{!-- 默认：使用文章数最多的 tags --}}
    <section class="gh-popular-tags">
        <h2 class="gh-section-title">{{t "热门主题"}}</h2>
        <div class="gh-tags-cloud">
            {{#get "tags" include="count.posts" order="count.posts desc" limit="10"}}
            {{#foreach tags}}
            <a href="{{url}}" class="gh-tag-item"
                style="{{#if feature_image}}background-image: url('{{img_url feature_image size="m"}}');{{/if}}{{#if accent_color}} --tag-accent-color: {{accent_color}};{{/if}}">
                <span class="gh-tag-overlay"></span>
                <span class="gh-tag-name">{{name}}</span>
            </a>
            {{/foreach}}
            {{/get}}
        </div>
        <footer class="gh-popular-tags-footer">
            <a class="gh-more-link" href="{{@site.url}}/tags">
                {{t "全部主题"}}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
            </a>
        </footer>
    </section>
{{/if}}
