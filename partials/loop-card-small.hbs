{{!-- Small Post Card - Styled like gh-card-more --}}
<article class="gh-card-small {{post_class}}">
    <a class="gh-card-small-link" href="{{url}}">
        {{#if feature_image}}
        <figure class="gh-card-small-image">
            <img
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 720w"
                sizes="(max-width: 768px) 100vw, 400px"
                src="{{img_url feature_image size="m"}}"
                alt="{{title}}"
                loading="lazy"
            >
        </figure>
        {{/if}}

        <div class="gh-card-small-content">
            {{#primary_tag}}
            <span class="gh-card-tag">{{name}}</span>
            {{/primary_tag}}
            <h3 class="gh-card-small-title">{{title}}</h3>
            {{#if excerpt}}
            <p class="gh-card-small-excerpt">{{excerpt words="20"}}</p>
            {{/if}}
            <div class="gh-card-small-meta">
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="YYYY年M月D日"}}</time>
                <span class="gh-meta-sep">&middot;</span>
                <span>{{reading_time}}</span>
            </div>
        </div>
    </a>
</article>
