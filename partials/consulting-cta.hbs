<section class="gh-consulting-cta gh-canvas">
    <hr class="gh-consulting-cta-divider">
    <h3 class="gh-consulting-cta-title">{{t "有技术问题需要解决？"}}</h3>
    <p class="gh-consulting-cta-desc">
        {{t "论文复现、模型部署、代码审查 —— 把问题带来，我帮你走通整条链路。"}}
    </p>
    <div class="gh-consulting-cta-actions">
        <span class="gh-consulting-qr">
            <span class="gh-consulting-cta-btn gh-consulting-cta-btn-primary" role="button">
                {{> "icons/wechat"}}
                {{t "微信聊聊"}}
            </span>
            <img src="https://yinguobing.com/assets/wechat.webp" alt="{{t "微信二维码"}}" class="gh-consulting-qr-img" loading="lazy">
        </span>
        <a href="https://yinguobing.com" class="gh-consulting-cta-btn">{{t "关于我"}}</a>
    </div>
</section>
