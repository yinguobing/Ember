{{!-- Large Post Card - 参考 Imperia 设计 --}}
<article class="gh-card gh-card-large {{post_class}}">
    <a href="{{url}}" class="gh-card-link"></a>
    
    <div class="gh-card-image-holder">
        {{#if feature_image}}
            <div class="gh-card-image">
                <img src="{{img_url feature_image size="l"}}" 
                     srcset="{{img_url feature_image size="m"}} 600w,
                             {{img_url feature_image size="l"}} 960w,
                             {{img_url feature_image size="xl"}} 1200w"
                     sizes="(max-width: 768px) 100vw, 600px"
                     alt="{{title}}" 
                     loading="lazy">
            </div>
        {{/if}}
    </div>
    
    <div class="gh-card-content">
        {{#primary_tag}}
            <a href="{{url}}" class="gh-card-tag" style="{{#if accent_color}}background-color: {{accent_color}}{{/if}}">{{name}}</a>
        {{/primary_tag}}
        <h3 class="gh-card-title"><a href="{{url}}">{{title}}</a></h3>
        {{#if excerpt}}
            <p class="gh-card-excerpt">{{excerpt words="25"}}</p>
        {{/if}}
        <div class="gh-card-meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
            <span class="gh-meta-sep">&middot;</span>
            <span>{{reading_time}}</span>
        </div>
    </div>
</article>
