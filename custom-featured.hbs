{{!< default}}

{{#post}}
    {{!-- Page header — title and excerpt from the Ghost page --}}
    {{#if feature_image}}
        <section class="gh-cover loading gh-outer">
            <img
                class="gh-cover-image"
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 720w,
                        {{img_url feature_image size="l"}} 960w,
                        {{img_url feature_image size="xl"}} 1200w,
                        {{img_url feature_image size="xxl"}} 2000w"
                sizes="100vw"
                src="{{img_url feature_image size="xl"}}"
                alt="{{title}}"
            >
            <div class="gh-cover-content">
                <h1 class="gh-cover-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="gh-cover-description">{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </section>
    {{else}}
        <section class="gh-pagehead gh-outer">
            <div class="gh-inner">
                <h1 class="gh-pagehead-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="gh-pagehead-description">{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </section>
    {{/if}}

    <main class="gh-main gh-outer">
        <div class="gh-inner">
            {{!-- 页面标题（如果没有 feature image） --}}
            {{#unless feature_image}}
                <section class="gh-pagehead">
                    <h1 class="gh-pagehead-title">{{title}}</h1>
                    {{#if custom_excerpt}}
                        <div class="gh-pagehead-description">{{custom_excerpt}}</div>
                    {{/if}}
                </section>
            {{/unless}}

            {{#get "posts" filter="featured:true" limit="12" include="authors,tags" order="published_at desc"}}
                {{#if posts}}
                    <div class="gh-feed gh-post-grid">
                        {{#foreach posts}}
                            {{> "loop-card-small"}}
                        {{/foreach}}
                    </div>
                {{else}}
                    <p class="gh-empty-message">暂无精选文章</p>
                {{/if}}
            {{/get}}
        </div>
    </main>
{{/post}}

{{#contentFor "body_class"}}{{#if post.feature_image}} is-head-transparent{{/if}}{{/contentFor}}
