{{!< default}} <main class="gh-main gh-outer">
    {{!-- Hero Section --}}
    {{> "hero-section"}}

    <div class="gh-inner">
        {{!-- What's New Section - 三栏布局 --}}
        {{#get "posts" limit="5" include="authors,tags" as |whats_new_posts|}}
        <section class="gh-whats-new">
            <h2 class="gh-section-title">近期发表</h2>

            <div class="gh-home-grid">
                {{!-- 第一栏：大文章 --}}
                <div class="gh-home-grid-col gh-home-grid-col-1">
                    {{#foreach whats_new_posts limit="1"}}
                    {{> "loop-card-large"}}
                    {{/foreach}}
                </div>

                {{!-- 第二栏：2篇小文章 --}}
                <div class="gh-home-grid-col gh-home-grid-col-2">
                    {{#foreach whats_new_posts from="2" limit="2"}}
                    {{> "loop-card-small"}}
                    {{/foreach}}
                </div>

                {{!-- 第三栏：2篇小文章 --}}
                <div class="gh-home-grid-col gh-home-grid-col-3">
                    {{#foreach whats_new_posts from="4" limit="2"}}
                    {{> "loop-card-small"}}
                    {{/foreach}}
                </div>
            </div>
        </section>
        {{/get}}

        {{!-- Featured Slider --}}
        {{#get "posts" filter="featured:true" limit="5" include="authors"}}
        {{#if posts}}
        <section class="gh-featured-slider">
            <h2 class="gh-section-title">精选内容</h2>
            <div class="gh-featured-slider-inner">

                {{!-- 图片 --}}
                <div class="gh-featured-slider-images">
                    {{#foreach posts}}
                    <div class="gh-featured-slide-image" data-index="{{@index}}">
                        {{#if feature_image}}
                        <a href="{{url}}">
                            <img src="{{img_url feature_image size=" l"}}" alt="{{title}}" loading="lazy">
                        </a>
                        {{/if}}
                    </div>
                    {{/foreach}}
                </div>

                {{!-- 文字内容 --}}
                <div class="gh-featured-slider-content">
                    {{#foreach posts}}
                    <div class="gh-featured-slide" data-index="{{@index}}">
                        <div class="gh-featured-slide-inner">
                            {{#primary_tag}}
                            <a href="{{url}}" class="gh-featured-slide-tag">{{name}}</a>
                            {{/primary_tag}}
                            <h2 class="gh-featured-slide-title"><a href="{{url}}">{{title}}</a></h2>
                            {{#if excerpt}}
                            <p class="gh-featured-slide-excerpt">{{excerpt words="30"}}</p>
                            {{/if}}
                            <div class="gh-featured-slide-meta">
                                {{#foreach authors}}{{#if @first}}{{name}}{{/if}}{{/foreach}}
                                <span class="gh-meta-sep">&middot;</span>
                                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="YYYY年M月D日"}}</time>
                            </div>
                        </div>
                    </div>
                    {{/foreach}}

                    {{!-- 控制按钮区域 --}}
                    <div class="gh-featured-slider-controls">
                        <button class="gh-slider-prev" aria-label="Previous">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="15 18 9 12 15 6"></polyline>
                            </svg>
                        </button>
                        <div class="gh-featured-slider-dots">
                            {{#foreach posts}}
                            <button class="gh-slider-dot" data-index="{{@index}}"></button>
                            {{/foreach}}
                        </div>
                        <button class="gh-slider-next" aria-label="Next">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </section>
        {{/if}}
        {{/get}}

        {{!-- Popular Tags --}}
        {{> "popular-tags"}}

        {{!-- More Posts Grid --}}
        {{#get "posts" limit="13" include="authors,tags" as |more_posts|}}
        {{#if more_posts.[7]}}
        <section class="gh-more-posts">
            <h2 class="gh-section-title">更早的文章</h2>
            <div class="gh-posts-grid gh-posts-grid-6">
                {{#foreach more_posts from="6" limit="8"}}
                {{> "loop-card-more"}}
                {{/foreach}}
            </div>

            <footer class="gh-more-posts-footer">
                <a class="gh-more-link" href="{{@site.url}}/page/2">
                    更多内容
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </a>
            </footer>
        </section>
        {{/if}}
        {{/get}}

    </div>
    </main>